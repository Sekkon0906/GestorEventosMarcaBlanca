# GESTEK — Backend (Express)
# Copia este archivo como .env y completa los valores reales.

# Servidor
PORT=3000
NODE_ENV=development

# Supabase (service_role: backend-only, NUNCA exponer al frontend)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=tu_service_role_key_aqui

# JWT para los QR de boletas (Fase D — check-in)
QR_JWT_SECRET=cambia_esto_por_un_secreto_seguro_minimo_32_chars

# CORS
FRONTEND_URL=http://localhost:5173

# Sentry (opcional)
SENTRY_DSN=

# Mercado Pago — cuenta plataforma (GESTEK), usada para el plan Pro
MP_PLATFORM_ACCESS_TOKEN=APP_USR-...
MP_PLATFORM_PUBLIC_KEY=APP_USR-...
# Secret para validar la firma HMAC de los webhooks MP (panel del webhook → configurar firma)
MP_WEBHOOK_SECRET=
PLAN_PRO_PRICE_USD=19.99
PLAN_PRO_PRICE=79900
PLAN_PRO_CURRENCY=COP
PLAN_PRO_DURATION_DAYS=30
# Dejar en false en producción
ALLOW_DEV_PRO_ACTIVATION=false

# URL pública del backend (usada en notification_url de las preferences MP)
API_PUBLIC_URL=

# Web Push (VAPID) — generar con: node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=mailto:admin@tu-dominio.com
